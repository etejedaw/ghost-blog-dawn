{{!< default}}

<main class="site-main">
    <section class="error-content gh-canvas">
        <div class="error-inner">
            <span class="error-code">{{statusCode}}</span>
            <h1 class="error-title">Algo salió mal</h1>
            <p class="error-description">
                {{#if message.statusMessage}}
                    {{message.statusMessage}}
                {{else}}
                    Ocurrió un error inesperado al cargar esta página.
                {{/if}}
            </p>

            <div class="error-actions">
                <a class="gh-btn gh-primary-btn" href="{{@site.url}}">Volver al inicio</a>
            </div>

            {{#if message.errorDetails}}
                <section class="error-stack">
                    <h3>Detalles técnicos</h3>
                    {{{message.errorDetails}}}
                </section>
            {{/if}}
        </div>
    </section>

    {{#get "posts" filter="featured:true" limit="3" as |suggested|}}
        {{#if suggested}}
            <section class="error-suggestions gh-canvas">
                <h2 class="error-suggestions-title">Pero quizá te interesen estos posts</h2>
                <div class="error-suggestions-grid">
                    {{#foreach suggested}}
                        <article class="error-suggestion {{post_class}}">
                            <div class="error-suggestion-media u-placeholder horizontal">
                                {{#if feature_image}}
                                    <img
                                        class="u-object-fit"
                                        srcset="{{> srcset}}"
                                        sizes="(min-width: 992px) 280px, (min-width: 600px) 45vw, 92vw"
                                        src="{{img_url feature_image size="m"}}"
                                        alt="{{title}}"
                                        loading="lazy"
                                    >
                                {{/if}}
                            </div>
                            <h3 class="error-suggestion-title">{{title}}</h3>
                            <a class="u-permalink" href="{{url}}" aria-label="{{title}}"></a>
                        </article>
                    {{/foreach}}
                </div>
            </section>
        {{else}}
            {{#get "posts" limit="3" as |latest|}}
                {{#if latest}}
                    <section class="error-suggestions gh-canvas">
                        <h2 class="error-suggestions-title">Pero quizá te interesen estos posts</h2>
                        <div class="error-suggestions-grid">
                            {{#foreach latest}}
                                <article class="error-suggestion {{post_class}}">
                                    <div class="error-suggestion-media u-placeholder horizontal">
                                        {{#if feature_image}}
                                            <img
                                                class="u-object-fit"
                                                srcset="{{> srcset}}"
                                                sizes="(min-width: 992px) 280px, (min-width: 600px) 45vw, 92vw"
                                                src="{{img_url feature_image size="m"}}"
                                                alt="{{title}}"
                                                loading="lazy"
                                            >
                                        {{/if}}
                                    </div>
                                    <h3 class="error-suggestion-title">{{title}}</h3>
                                    <a class="u-permalink" href="{{url}}" aria-label="{{title}}"></a>
                                </article>
                            {{/foreach}}
                        </div>
                    </section>
                {{/if}}
            {{/get}}
        {{/if}}
    {{/get}}
</main>
