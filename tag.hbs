{{!< default}}

<main class="site-main">

    {{#tag}}
    <section class="tag">

        <div class="gh-canvas">

            <h1 class="tag-name">{{name}}</h1>

            {{#if description}}
                <div class="tag-description">{{description}}</div>
            {{/if}}


        </div>

    </section>
    {{/tag}}

    <div class="post-feed gh-feed gh-canvas">
        {{#foreach posts}}
            {{> "loop"}}
        {{/foreach}}
    </div>

    {{pagination}}

</main>